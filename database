CREATE DATABASE company;
USE company;

-- Users table (HR/Admin/Recruiter)
CREATE TABLE users (
id INTEGER PRIMARY KEY,
username VARCHAR(50) UNIQUE NOT NULL,
email VARCHAR(50) UNIQUE NOT NULL,
password VARCHAR(50) NOT NULL,
role VARCHAR(50)
);

-- Candidates table
CREATE TABLE candidates (
id INTEGER PRIMARY KEY,
full_name VARCHAR(50),
email VARCHAR(50) UNIQUE,
phone VARCHAR(20),
education VARCHAR(200),
experience_years INTEGER,
skills TEXT,
resume_path VARCHAR(255)
);

-- Job descriptions table
CREATE TABLE job_descriptions (
id INTEGER PRIMARY KEY,
title VARCHAR(150),
department VARCHAR(100),
required_skills TEXT,
experience_required INTEGER,
education_required VARCHAR(200),
description TEXT,

-- recruiter/admin who created the job  
created_by INTEGER,  
FOREIGN KEY (created_by) REFERENCES users(id)

);

-- Applications table (connect candidates with jobs)
CREATE TABLE applications (
id INTEGER PRIMARY KEY,
candidate_id INTEGER,  
job_id INTEGER,  
application_date DATE,  
status VARCHAR(50),  

FOREIGN KEY (candidate_id) REFERENCES candidates(id),  
FOREIGN KEY (job_id) REFERENCES job_descriptions(id)

);


-- Resume and JD text save table 

CREATE TABLE ai_inputs (
    id INTEGER PRIMARY KEY,
    
    candidate_id INTEGER,
    job_id INTEGER,
    
    -- extracted resume text
    resume_text TEXT,
    
    -- JD text sent to AI
    jd_text TEXT,
    
    uploaded_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (candidate_id) REFERENCES candidates(id),
    FOREIGN KEY (job_id) REFERENCES job_descriptions(id)
);


-- Ai generated questins save table  ---
CREATE TABLE interview_questions (
    id INTEGER PRIMARY KEY,

    candidate_id INTEGER,
    job_id INTEGER,

    question TEXT NOT NULL,

    -- technical / hr / aptitude
    question_type VARCHAR(50),

    generated_at DATETIME DEFAULT CURRENT_TIMESTAMP,

    FOREIGN KEY (candidate_id) REFERENCES candidates(id),
    FOREIGN KEY (job_id) REFERENCES job_descriptions(id)
);
